# Copy this file to .env and paste your key in.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional. The Claude model to use. Defaults to claude-sonnet-5 if unset.
# Other options: claude-haiku-4-5 (cheaper/faster), claude-opus-4-8 (most capable).
MODEL=claude-sonnet-5
